{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach: snapd (remote)",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "host": "${input:targetIP}",
      "port": "${input:debugPort}",
      "preLaunchTask": "Copy+Debug snapd on arm64 target",
      "dlvLoadConfig": {
        "followPointers": true,
        "maxVariableRecurse": 3,
        "maxStringLen": 1024,
        "maxArrayValues": 128,
        "maxStructFields": -1
      }
    }
  ],
  "inputs": [
    {
      "id": "targetIP",
      "type": "promptString",
      "description": "Delve host (IP or hostname)",
      "default": "192.168.178.116"
    },
    {
      "id": "debugPort",
      "type": "promptString",
      "description": "Delve port",
      "default": "2345"
    }
  ]
}
