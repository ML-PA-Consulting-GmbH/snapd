{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build snapd (arm64)",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "GOOS": "linux",
          "GOARCH": "arm64",
          "CGO_ENABLED": "0",
          "CC": "aarch64-linux-gnu-gcc",
          "CXX": "aarch64-linux-gnu-g++"
        }
      },
      "command": "bash",
      "args": [
        "-lc",
        "mkdir -p build-debug && go build -tags=\"snapdusergo\" -o build-debug/snapd_arm64 ./cmd/snapd"
      ],
      "problemMatcher": []
    },
    {
      "label": "copy snapd to target",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}" },
      "command": "${workspaceFolder}/debug-tools/copy-file-to-remote-wait-till-unlocked.sh",
      "args": [ "${input:targetIP}", "build-debug/snapd_arm64" ],
      "problemMatcher": []
    },
    {
      "label": "copy snapd to target (no wait)",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}" },
      "command": "${workspaceFolder}/debug-tools/copy-file-to-remote.sh",
      "args": [ "${input:targetIP}", "build-debug/snapd_arm64" ],
      "problemMatcher": []
    },
    {
      "label": "Copy debug script to target",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}" },
      "command": "${workspaceFolder}/debug-tools/copy-file-to-remote.sh",
      "args": [ "${input:targetIP}", "debug-tools/delve-remote-debugging.sh" ],
      "problemMatcher": []
    },
    {
      "label": "Copy arm64 delve to target",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}" },
      "command": "${workspaceFolder}/debug-tools/copy-file-to-remote.sh",
      "args": [ "${input:targetIP}", "debug-tools/delve-arm64" ],
      "problemMatcher": []
    },
    {
      "label": "prepare remote debug tools",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}" },
      "command": "bash",
      "args": [
        "-lc",
        "set -e; ${workspaceFolder}/debug-tools/copy-file-to-remote.sh ${input:targetIP} debug-tools/delve-remote-debugging.sh; ${workspaceFolder}/debug-tools/copy-file-to-remote.sh ${input:targetIP} debug-tools/delve-arm64; ssh ${input:targetIP} \"chmod +x ~/delve-remote-debugging.sh ~/delve-arm64\""
      ],
      "problemMatcher": []
    },
    {
      "label": "start remote delve (snapd)",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}" },
      "command": "bash",
      "args": [
        "-lc",
        "ssh ${input:targetIP} \"/bin/bash ~/delve-remote-debugging.sh ~/snapd_arm64 ${input:debugPort}\""
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "group": "Snapd Output",
        "clear": true
      }
    },
    {
      "label": "Copy+Debug snapd on arm64 target",
      "dependsOn": [
        "build snapd (arm64)",
        "copy snapd to target"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "First-time: prepare+build+copy+start (snapd)",
      "dependsOn": [
        "prepare remote debug tools",
        "build snapd (arm64)",
        "copy snapd to target (no wait)",
        "start remote delve (snapd)"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "Prepare remote (once)",
      "dependsOn": [
        "prepare remote debug tools"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "clear copy cache",
      "type": "shell",
      "options": { "cwd": "${workspaceFolder}" },
      "command": "bash",
      "args": [
        "-lc",
        "rm -rf \"${XDG_CACHE_HOME:-$HOME/.cache}/copy-file-to-remote\" && echo Cleared: ${XDG_CACHE_HOME:-$HOME/.cache}/copy-file-to-remote"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "targetIP",
      "type": "promptString",
      "description": "SSH target (user@host)",
      "default": "root@192.168.178.116"
    },
    {
      "id": "debugPort",
      "type": "promptString",
      "description": "Delve port",
      "default": "2345"
    }
  ]
}
